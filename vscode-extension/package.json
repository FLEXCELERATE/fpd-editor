{
  "name": "fpd-vscode-extension",
  "displayName": "FPD Language Support",
  "description": "Syntax highlighting, IntelliSense, diagnostics, and live diagram preview for FPD (Formalized Process Description, VDI 3682)",
  "version": "0.1.0",
  "publisher": "FLEXCELERATE",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/FLEXCELERATE/fpd-editor"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Visualization"
  ],
  "license": "MIT",
  "keywords": [
    "fpd",
    "vdi3682",
    "formalized-process-description",
    "process",
    "diagram"
  ],
  "activationEvents": [
    "onLanguage:fpd",
    "onCommand:fpd.preview.show"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "fpd",
        "aliases": [
          "FPD",
          "Formalized Process Description"
        ],
        "extensions": [
          ".fpd"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "fpd",
        "scopeName": "source.fpd",
        "path": "./syntaxes/fpd.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "fpd.preview.show",
        "title": "FPD: Show Preview",
        "icon": "$(preview)"
      },
      {
        "command": "fpd.export.svg",
        "title": "FPD: Export SVG"
      },
      {
        "command": "fpd.export.png",
        "title": "FPD: Export PNG"
      },
      {
        "command": "fpd.export.pdf",
        "title": "FPD: Export PDF"
      },
      {
        "command": "fpd.export.xml",
        "title": "FPD: Export VDI 3682 XML"
      },
      {
        "command": "fpd.export.text",
        "title": "FPD: Export FPD Text"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceLangId == fpd",
          "command": "fpd.preview.show",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "fpd.preview.show",
          "when": "resourceLangId == fpd"
        },
        {
          "command": "fpd.export.svg",
          "when": "resourceLangId == fpd"
        },
        {
          "command": "fpd.export.png",
          "when": "resourceLangId == fpd"
        },
        {
          "command": "fpd.export.pdf",
          "when": "resourceLangId == fpd"
        },
        {
          "command": "fpd.export.xml",
          "when": "resourceLangId == fpd"
        },
        {
          "command": "fpd.export.text",
          "when": "resourceLangId == fpd"
        }
      ]
    },
    "configuration": {
      "title": "FPD",
      "properties": {
        "fpd.backend.url": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "URL of the FPD backend API server"
        },
        "fpd.backend.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the FPD backend server if not running"
        },
        "fpd.preview.autoUpdate": {
          "type": "boolean",
          "default": true,
          "description": "Automatically update the preview panel when editing"
        },
        "fpd.preview.updateDelay": {
          "type": "number",
          "default": 500,
          "description": "Delay in milliseconds before updating the preview after typing (debounce)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.x",
    "@typescript-eslint/parser": "^6.x",
    "@vscode/test-electron": "^2.3.x",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.x",
    "typescript": "^5.3.x"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}
