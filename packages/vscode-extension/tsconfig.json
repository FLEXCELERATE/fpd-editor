{
    "extends": "@fpd-editor/tsconfig/vscode-extension.json",
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./out",
        "lib": ["ES2020"],
        "esModuleInterop": true,
        "declaration": false,
        "declarationMap": false
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", ".vscode-test", "out", "src/**/*.test.ts"]
}
