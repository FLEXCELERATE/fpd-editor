{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "FPD",
    "scopeName": "source.fpd",
    "fileTypes": [".fpd"],
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#block-delimiters"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#connection-operators"
        },
        {
            "include": "#braces"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#identifiers"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.fpd",
                    "match": "//.*$",
                    "comment": "Line comment starting with //"
                }
            ]
        },
        "block-delimiters": {
            "patterns": [
                {
                    "name": "keyword.control.fpd",
                    "match": "@(startfpd|endfpd)\\b",
                    "comment": "Block start and end delimiters"
                },
                {
                    "name": "keyword.annotation.fpd",
                    "match": "@(boundary|internal)\\b",
                    "comment": "Placement annotations for states"
                }
            ]
        },
        "braces": {
            "patterns": [
                {
                    "name": "punctuation.definition.block.fpd",
                    "match": "[{}]",
                    "comment": "Braces for system blocks"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.fpd",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.fpd",
                            "match": "\\\\."
                        }
                    ],
                    "comment": "Double-quoted string"
                }
            ]
        },
        "connection-operators": {
            "patterns": [
                {
                    "name": "keyword.operator.connection.usage.fpd",
                    "match": "<\\.\\.>",
                    "comment": "Usage connection operator"
                },
                {
                    "name": "keyword.operator.connection.alternative.fpd",
                    "match": "-\\.->",
                    "comment": "Alternative flow connection operator"
                },
                {
                    "name": "keyword.operator.connection.parallel.fpd",
                    "match": "==>",
                    "comment": "Parallel flow connection operator"
                },
                {
                    "name": "keyword.operator.connection.flow.fpd",
                    "match": "-->",
                    "comment": "Flow connection operator"
                }
            ],
            "comment": "Connection operators (order matters: longer patterns first for greedy matching)"
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.element.fpd",
                    "match": "\\b(product|energy|information|process_operator|technical_resource)\\b",
                    "comment": "Element type keywords"
                },
                {
                    "name": "keyword.other.fpd",
                    "match": "\\b(title|system)\\b",
                    "comment": "Other keywords"
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "name": "variable.other.identifier.fpd",
                    "match": "\\b[a-zA-Z_]\\w*\\b",
                    "comment": "Identifiers (element IDs, etc.)"
                }
            ]
        }
    }
}
